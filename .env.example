DATABASE_URL=postgres://postgres:postgres@localhost:5432/heritier
PORT=3001
CRON_TICK=0 * * * *
TIMEZONE=America/Toronto
NODE_ENV=development
LOG_LEVEL=debug
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://client-jeux-millionnaire.vercel.app,https://app.nowis.store,https://nowis.store
JWT_SECRET=change-me-please
ADMIN_EMAIL=you@example.com
ADMIN_VERIFY_SECRET=
SKIP_EMAIL_VERIFICATION=false
MIGRATE_ON_BOOT=false

# OpenAI API pour génération automatique de questions quiz
OPENAI_API_KEY=sk-...

# App origin (utilisé pour les liens d'email reset)
APP_ORIGIN=http://localhost:3000
SITE_ORIGIN=https://nowis.store

# Cookies / session
# En production, laissez vide pour des cookies host-only sur app.nowis.store,
# ou définissez .nowis.store si vous devez partager entre sous-domaines.
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
ALLOW_VERCEL_PREVIEWS=false

# SMTP (optionnel pour email reset; sinon fallback console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Jeux du Millionaire" <no-reply@example.com>
